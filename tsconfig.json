{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "WebWorker"],
		"strict": true,
		"declaration": true,
		"outDir": "dist",
		"rootDir": "src",
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts"]
}
